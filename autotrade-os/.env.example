APP_NAME=AutoTrade OS
DATABASE_URL=postgresql+psycopg://autotrade:autotrade@localhost:5432/autotrade
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Critical safety default. Real-money execution must never be enabled implicitly.
ENABLE_LIVE_TRADING=false

PAPER_STARTING_CASH=100000
DEFAULT_FEES_BPS=1
DEFAULT_SLIPPAGE_BPS=2
DEFAULT_MAX_RISK_PER_TRADE=0.02
MARKET_TIMEZONE=America/New_York

# Optional market data provider keys can be added later.
# ALPHA_VANTAGE_API_KEY=
# IBKR_HOST=
# IBKR_PORT=
# IBKR_CLIENT_ID=

