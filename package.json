{
  "name": "restaurant-reservation-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- sh -c 'node scripts/validate-env.mjs && next dev'",
    "build": "dotenv -e .env -- sh -c 'node scripts/validate-env.mjs && prisma generate && next build'",
    "start": "dotenv -e .env -- sh -c 'node scripts/validate-env.mjs && next start'",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node scripts/seed.mjs",
    "db:studio": "prisma studio",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.0",
    "prisma": "6.19.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
